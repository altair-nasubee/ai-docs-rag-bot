# ===== API キー =====
# Groq（回答生成 LLM）: https://console.groq.com/keys で取得
# 埋め込みはローカル ONNX（fastembed）で計算するためキー不要。必要なのはこれだけ。
GROQ_API_KEY=your-groq-api-key

# ===== モデル設定（未設定なら既定値が使われる）=====
# 回答生成 LLM。代替: qwen3-32b（日本語重視）/ llama-3.1-8b-instant（高速・制限回避）
GROQ_MODEL=llama-3.3-70b-versatile

# 埋め込みモデル（fastembed のローカル ONNX）。多言語・クロスリンガル対応。
EMBED_MODEL=intfloat/multilingual-e5-small

# 埋め込み次元数
EMBED_DIM=384

# e5 系の必須プレフィックス。プレフィックス不要モデルに切替える場合は両方を空にする。
# EMBED_QUERY_PREFIX=query:
# EMBED_PASSAGE_PREFIX=passage:

# git push space main の実行時の Username と Pass
HF_USER=<USERNAME of Hugging Face Spaces>
HF_TOKEN=<TOKEN of Hugging Face Spaces>
