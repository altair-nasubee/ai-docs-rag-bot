# ===== API キー =====
# Groq（回答生成 LLM）: https://console.groq.com/keys で取得
GROQ_API_KEY=your-groq-api-key

# Google AI Studio（Gemini 埋め込み）: https://aistudio.google.com/apikey で取得
GOOGLE_API_KEY=your-google-api-key

# ===== モデル設定（未設定なら既定値が使われる）=====
# 回答生成 LLM。代替: qwen3-32b（日本語重視）/ llama-3.1-8b-instant（高速・制限回避）
GROQ_MODEL=llama-3.3-70b-versatile

# 埋め込みモデル（LangChain の models/ プレフィックス付き）
EMBED_MODEL=models/gemini-embedding-001

# 埋め込み次元数。3072 未満のため取得ベクトルは L2 正規化が必要
EMBED_DIM=768
