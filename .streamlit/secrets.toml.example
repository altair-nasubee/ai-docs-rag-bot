# Streamlit Community Cloud / Hugging Face Spaces の Secrets に貼り付ける内容のサンプル。
# 実体（secrets.toml）はコミットしない（.gitignore で除外済み）。
# 埋め込みはローカル ONNX のため、必要なキーは Groq のみ。

GROQ_API_KEY = "your-groq-api-key"

# 任意（未設定なら config.py の既定値が使われる）
GROQ_MODEL = "llama-3.3-70b-versatile"
EMBED_MODEL = "intfloat/multilingual-e5-small"
EMBED_DIM = "384"
